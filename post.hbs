{{!< default}}

{{! The comment above "< default" means - insert everything in this file into
    the {body} of the default.hbs template, which contains our header/footer. }}

{{#post}}

<!-- start: #single -->
<main id="single" class="main grid-container no-sidebar classic">

    <!-- start: .center -->
    <div class="center content">

        <!-- start: .content -->
        <div class="left-content np-mobile">

            <article class="main-article section post-access-{{visibility}} primary-tag-{{primary_tag.slug}} {{post_class}}">

                <header> 
                    {{#if feature_image}}
                        <div class="featured-image">
                            <img class="fullwidth" src="{{img_url feature_image size="classic"}}" fetchpriority="high" decoding="async" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
                            <p class="featured-image-caption border-effect">{{feature_image_caption}}</p>
                        </div>
                    {{/if}}      
                    <div class="info textcenter">    
                        <h1 class="main-title title ularge">{{title}}</h1>
                        {{#if custom_excerpt}} 
                            <p class="excerpt primary-tag-{{primary_tag.slug}}">{{{custom_excerpt}}}</p>
                        {{/if}}
                        <!-- start: .meta -->
                        <div class="meta inline">
                            {{> meta-data/primary-category}}
                            {{> meta-data/date}}
                            {{> meta-data/reading-time}}
                            {{> meta-data/author}}
                        </div>
                        <!-- end: .meta -->   
                        <div class="clear"></div>     
                    </div>
                            
                    <div class="clear"></div>
                </header>

                <section class="post-content">
                    {{#if access}}
                    
                        <div class="text border-effect">{{content}}</div>   

                        <div class="meta-bottom epcl-flex">       
                            <!-- start: .share-buttons -->
                            <div class="share-buttons epcl-social-buttons fill-color">
                                <h5 class="title usmall fw-semibold">{{t "Share on:"}}</h5>                            
                                <a class="bluesky" href="https://bsky.app/intent/compose?text={{encode title}}%0A{{url absolute="true"}}" target="_blank">
                                    <svg class="icon" style="fill:#01A6FF;"><use href="#bluesky-icon"></use></svg>
                                </a>
                                <a class="threads" href="https://www.threads.com/intent/post?text={{encode title}}&url={{url absolute="true"}}" target="_blank">
                                    <svg class="icon" style="fill:var(--epcl-text-color);"><use href="#threads-icon"></use></svg>
                                </a>
                                <a class="reddit" href="https://www.reddit.com/submit?title={{encode title}}&url={{url absolute="true"}}" target="_blank">
                                    <svg class="icon" style="fill:#FF4500;"><use href="#reddit-icon"></use></svg>
                                </a>                 
                                <a class="email" href="mailto:?subject={{encode title}}&body={{url absolute="true"}}" target="_blank">
                                    <svg class="icon"><use href="#email-icon"></use></svg>
                                </a>
                                <a class="share" onClick="sharePost({url:'{{url absolute="true"}}'})">
                                    <svg class="icon" style="fill:var(--epcl-text-color);"><use href="#share-icon"></use></svg>
                                </a>
                                <div class="clear"></div>
                            </div>
                            <!-- end: .share-buttons -->    
                            <div class="sep dot"></div>
                            <p class="last-update"><strong>{{t "Last Update:"}}</strong> {{date updated_at format="MMMM DD, YYYY"}}</p>                          
                        </div> 

                        {{#if tags}}                
                            <div class="tags-list border-effect">
                                <p><strong>{{t "Tagged in:"}}</strong></p> 
                                {{tags separator=", "}}
                            </div>  
                        {{/if}}
                                            
                    {{else}}
                        {{> content-cta}}
                    {{/if}}
                </section>

            </article>

            <div class="clear"></div>

            {{> single/siblings-articles}}
               
            <div class="clear"></div>
            
            {{> single/comments-area}}   

        </div>
        <!-- end: .content -->           

        <div class="clear"></div>

    </div>
    <!-- end: .center -->

</main>
<!-- end: #single -->

{{/post}}
